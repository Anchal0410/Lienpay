# ─────────────────────────────────────────────
# LienPay Backend — Environment Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# ── APP ──────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=LienPay
APP_URL=http://localhost:3000

# ── DATABASE (PostgreSQL) ─────────────────────
# Prefer a single connection string in production (e.g. Neon/Railway)
# Example:
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=lienpay_db
DB_USER=lienpay_user
DB_PASSWORD=your_strong_password_here
DB_SSL=false

# ── REDIS (Sessions + OTP Cache) ──────────────
# For local testing you can keep Redis disabled.
# Set REDIS_ENABLED=true (or set REDIS_URL) if you want Redis-backed features.
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────
JWT_SECRET=your_very_long_random_secret_here_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_very_long_random_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ── ENCRYPTION (for PAN, Aadhaar last4) ──────
# 32 bytes (64 hex chars) recommended.
# In dev, if this is invalid/missing the backend falls back to a derived key.
ENCRYPTION_KEY=64_char_hex_key_here_aes_256_cbc
ENCRYPTION_IV=16_char_hex_iv_here

# ── SMS GATEWAY (MSG91) ───────────────────────
# Mode: mock = log to console | real = send actual SMS
SMS_MODE=mock
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=LNPAY
MSG91_TEMPLATE_OTP=your_dlt_template_id
MSG91_TEMPLATE_PAYMENT_DUE=your_dlt_template_id
MSG91_TEMPLATE_MARGIN_CALL=your_dlt_template_id
MSG91_TEMPLATE_TXN_SUCCESS=your_dlt_template_id

# ── PAN VERIFICATION (Setu) ───────────────────
# Mode: mock | real
PAN_VERIFY_MODE=mock
SETU_API_KEY=your_setu_api_key
SETU_PRODUCT_INSTANCE_ID=your_product_instance_id

# ── AADHAAR eKYC (Digio / Signzy) ────────────
# Mode: mock | real
AADHAAR_MODE=mock
DIGIO_API_KEY=your_digio_api_key
DIGIO_API_SECRET=your_digio_secret

# ── CKYC (via Lending Partner) ────────────────
# Mode: mock | real
CKYC_MODE=mock
CKYC_API_URL=https://api.lendingpartner.com/ckyc
CKYC_API_KEY=from_lending_partner

# ── CREDIT BUREAU (via Lending Partner) ───────
# Mode: mock | real
BUREAU_MODE=mock
BUREAU_API_URL=https://api.lendingpartner.com/bureau
BUREAU_API_KEY=from_lending_partner

# ── AML SCREENING (ComplyAdvantage) ───────────
# Mode: mock | real
AML_MODE=mock
COMPLY_API_KEY=your_comply_advantage_key
COMPLY_API_URL=https://api.complyadvantage.com

# ── ACCOUNT AGGREGATOR (Sahamati) ─────────────
# Mode: mock | real
AA_MODE=mock
AA_FIU_ID=your_fiu_id
AA_CLIENT_ID=your_aa_client_id
AA_CLIENT_SECRET=your_aa_client_secret
AA_API_URL=https://api.onemoney.in

# ── AMFI NAV FEED (REAL - free public API) ────
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt

# ── CAMS PLEDGE API ───────────────────────────
# Mode: mock | real
CAMS_MODE=mock
CAMS_API_URL=https://api.camsonline.com/pledge
CAMS_API_KEY=from_cams_partnership
CAMS_CLIENT_ID=from_cams_partnership

# ── KFINTECH PLEDGE API ───────────────────────
# Mode: mock | real
KFINTECH_MODE=mock
KFINTECH_API_URL=https://api.kfintech.com/pledge
KFINTECH_API_KEY=from_kfintech_partnership

# ── NBFC / LENDING PARTNER CORE ───────────────
# Mode: mock | real
NBFC_MODE=mock
NBFC_API_URL=https://api.lendingpartner.com
NBFC_API_KEY=from_lending_partner_agreement
NBFC_CLIENT_ID=lienpay_lsp_id
NBFC_NAME=FinServNBFC Ltd.
NBFC_WEBHOOK_SECRET=shared_secret_for_webhook_verification

# ── PSP BANK / UPI ────────────────────────────
# Mode: mock | real
UPI_MODE=mock
PSP_API_URL=https://api.pspbank.com/upi
PSP_API_KEY=from_psp_bank

# ── NACH / AUTO-DEBIT ────────────────────────
NACH_MODE=mock
NACH_API_URL=https://api.lendingpartner.com/nach
NACH_API_KEY=from_lending_partner

# ── RISK ENGINE ───────────────────────────────
RISK_ENGINE_URL=http://localhost:3000/internal/risk
# Policy limits
RISK_MAX_CREDIT_LIMIT=500000
RISK_MIN_CREDIT_LIMIT=10000
RISK_MIN_BUREAU_SCORE=600
RISK_FRAUD_SCORE_THRESHOLD=70
# LTV caps (RBI mandated)
RISK_LTV_EQUITY=0.50
RISK_LTV_DEBT=0.80
RISK_LTV_INTERNAL_BUFFER=0.10

# ── LSP COMMERCIAL ────────────────────────────
LSP_SOURCING_FEE_PERCENT=1.8
LSP_TECH_FEE_MONTHLY=50000
LSP_GST_PERCENT=18

# ── LOGGING ──────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/lienpay.log

# ── RATE LIMITING ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_MAX_PER_MOBILE_PER_DAY=5
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=15

# ── RISK ENGINE ───────────────────────────────────────────────
APR_TIER_A=14.99
APR_TIER_B=15.99
APR_TIER_C=17.99
RISK_MIN_CREDIT_LIMIT=10000
RISK_MAX_CREDIT_LIMIT=5000000
RISK_FRAUD_SCORE_THRESHOLD=70

# Dashboard Auth
ADMIN_TOKEN=lienpay-admin-2026
LENDER_TOKEN=lienpay-lender-2026
